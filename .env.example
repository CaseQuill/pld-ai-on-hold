# Basic auth (leave unset to disable)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=changeme

# ElevenLabs
ELEVENLABS_API_KEY=sk_...
EL_AGENT_ID=agent_3801knmqeg57ex08r7erqccsc7fz

# Comma-separated SIP trunk phnum_ IDs (round-robin pool)
# Provision 3 dedicated numbers in EL dashboard for Pond Lehocky
EL_PHNUM_IDS=phnum_xxx,phnum_yyy,phnum_zzz

# Dynamic variable identifying the call source
EL_ENV_TAG=pdl

# EL post-call webhook shared secret (set in EL dashboard -> Webhooks)
EL_WEBHOOK_SECRET=whsec_...

# Upstash Redis (Vercel KV integration also sets these automatically)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Neon Postgres (Vercel Postgres integration sets this automatically)
DATABASE_URL=postgres://...
